{
  "name": "financeflow",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "install:web": "npm --prefix apps/web install",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "android": "npm --prefix apps/mobile run android",
    "typecheck:mobile": "npm --prefix apps/mobile run typecheck",
    "install:mobile": "npm --prefix apps/mobile install",
    "install:all": "npm run install:web && npm run install:mobile"
  },
  "engines": {
    "node": ">=14.21.3",
    "npm": ">=6.14.16"
  },
  "dependencies": {
    "fnm": "0.0.0"
  }
}
